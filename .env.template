# ═══════════════════════════════════════════════════════════════════════════════
# NEXUS Core – Environment Configuration Template
# Copy to .env and fill in your values before starting the server.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Discovery ──────────────────────────────────────────────────────────────────
# Required for nexus_discover_source.
# Obtain a free key at https://tavily.com
TAVILY_API_KEY="tvly-xxxx"

# ── Embedding provider ────────────────────────────────────────────────────────
# Valid values: OLLAMA | OPENAI
EMBEDDING_SOURCE="OLLAMA"

# OLLAMA – local model via Ollama daemon
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="nomic-embed-text"

# OPENAI – cloud embeddings (requires OPENAI_API_KEY)
# EMBEDDING_SOURCE="OPENAI"
OPENAI_API_KEY=""
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# ── LLM provider (used by nexus_verify_compliance) ────────────────────────────
# Valid values: OLLAMA | OPENAI
LLM_PROVIDER="OLLAMA"
LLM_MODEL="llama3"

# ── Storage paths ─────────────────────────────────────────────────────────────
# Defaults resolve relative to /opt/nexus/data/ – override with absolute paths.
# NEXUS_STORAGE_PATH="/opt/nexus/data/indices"
# SQLITE_DB_PATH="/opt/nexus/data/nexus.db"

# ── Safety ────────────────────────────────────────────────────────────────────
# Minimum relevance score [0.0–1.0] for semantic search results.
NEXUS_SIMILARITY_THRESHOLD=0.7
